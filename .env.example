OPENAI_API_KEY=
# Modelo padrão do Agente de Vendas (Responses / Chat)
OPENAI_MODEL=gpt-5-mini
# Fonte das instruções: local (instructions.py) | openai (Prompt salvo Responses API)
AGENT_PROMPT_SOURCE=local
OPENAI_PROMPT_ID=
OPENAI_PROMPT_VERSION=
# Se o Prompt externo falhar, usa instructions.py uma única vez
OPENAI_PROMPT_FALLBACK_LOCAL=true
SUPABASE_URL=
# Backend do agente: preferir service_role/secret (bypassa RLS).
# SUPABASE_SERVICE_ROLE_KEY tem prioridade sobre SUPABASE_KEY.
# No /status: supabase_key_source = service_role | fallback_key | missing
# Nunca use anon/publishable no servidor se RLS estiver ativo em clientes.
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Tabelas do agente (explícitas — sem fallback silencioso)
# Use as tabelas reais do seu schema Supabase.
CLIENTES_TABLE=clientes
# conversas = thread/atendimento PulseDesk (contact_phone, last_message, …).
# Histórico do agente fica em clientes.historico (+ contexto_venda).
# Não use conversas como tabela de mensagens individuais (cliente_id/tipo/mensagem).
CONVERSAS_TABLE=conversas
# Alias legado (só se CLIENTES_TABLE/CONVERSAS_TABLE não estiverem definidos)
# AGENT_CLIENTES_TABLE=clientes
# AGENT_HISTORICO_TABLE=conversas

MERCOS_BASE_URL=https://sandbox.mercos.com/api
MERCOS_APPLICATION_TOKEN=
MERCOS_COMPANY_TOKEN=
MERCOS_CACHE_SEGUNDOS=600
MERCOS_OCULTAR_EXEMPLOS=true
MERCOS_CLIENTE_PADRAO=
# Homologação Ajuste de estoque: piso específico (>= throttle global; default 20)
# MERCOS_HOMOLOG_ESTOQUE_INTERVALO_SEGUNDOS=20
# MERCOS_THROTTLE_INTERVALO_SEGUNDOS=10
# Opcional — paths oficiais se a Mercos informar (homologação)
# MERCOS_PATH_TIPOS_PEDIDO=/v1/...
# MERCOS_PATH_TABELAS_PRECO_PRODUTO=/v1/...

WEBHOOK_MAX_IDADE_MINUTOS=15

PRODUTOS_FONTE=supabase

PULSEDESK_BRIDGE_ENABLED=true
PULSEDESK_PEDIDOS_ENABLED=true
PULSEDESK_AGENT_CANAL_ID=agent-vendas-zapi
# true = ao fechar venda no WhatsApp, cria pedido real no Mercos
MERCOS_CRIAR_PEDIDO=true

# Etapa 5 — checkout / fechamento seguro
# CHECKOUT_ENABLED=true → conduz compra (COMPRA/PAGAMENTO/ENTREGA)
# CHECKOUT_CREATE_ORDER=false → NÃO cria pedido automático (padrão seguro)
# Para criar pedido real: CHECKOUT_CREATE_ORDER=true + MERCOS_CRIAR_PEDIDO/PULSEDESK
# dry_run=true ou persistir=false nunca criam pedido, mesmo com flags true
CHECKOUT_ENABLED=true
CHECKOUT_CREATE_ORDER=false

SYNC_TOKEN=

# Provedor WhatsApp legado: ultramsg | zapi
WHATSAPP_PROVIDER=ultramsg

# UltraMsg (beta)
ULTRAMSG_INSTANCE_ID=instance184714
ULTRAMSG_TOKEN=coloque_o_token_real_aqui
# Opcional: se vazio, monta https://api.ultramsg.com/{ULTRAMSG_INSTANCE_ID}
ULTRAMSG_API_URL=https://api.ultramsg.com/instance184714/

# Z-API (mantido — use WHATSAPP_PROVIDER=zapi)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_BASE_URL=https://api.z-api.io

# Brevo WhatsApp (provedor oficial do WhatsApp — NÃO é a persona do agente)
# Persona = Agente de Vendas da xNamai
# Fluxo: WhatsApp → Brevo → POST /webhooks/brevo/whatsapp → agents.vendas → Brevo WhatsApp API
# BREVO_API_KEY=
# BREVO_WEBHOOK_SECRET=
# BREVO_BASE_URL=https://api.brevo.com
# Em produção WhatsApp use:
# BREVO_REPLY_MODE=whatsapp
# BREVO_SENDER_NUMBER=5511XXXXXXXXX
# BREVO_SEND_URL=   (opcional; default https://api.brevo.com/v3/whatsapp/sendMessage)
# BREVO_TIMEOUT_SEGUNDOS=20
# Modo conversations (chat web) só se necessário:
# BREVO_AGENT_ID=
# BREVO_AGENT_EMAIL=
# BREVO_AGENT_NAME=xNamai Vendas
# Auth webhook: Header X-Webhook-Token: <BREVO_WEBHOOK_SECRET>

VENDEDOR_WHATSAPP=

PIX_CHAVE=contato@xnamai.com.br
PIX_NOME=Xnamai
PIX_CIDADE=Curitiba

# Cerebro do WhatsApp: novo (Agente de Vendas xNamai) | legado (xNaMai Responses API)
AGENT_VERSION=novo

# Limites do agente (evita loop/travamento em /chat)
# AGENT_MAX_TOOL_ROUNDS=3
# AGENT_TOOL_TIMEOUT_SEGUNDOS=12
# AGENT_TOTAL_TIMEOUT_SEGUNDOS=55
# CHAT_TIMEOUT_SEGUNDOS=70

# Audio inbound (Whisper). Resposta continua em texto (sem TTS).
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# AUDIO_MAX_BYTES=5242880
# AUDIO_DOWNLOAD_TIMEOUT=25

# Script comercial Xnamai (WhatsApp)
XNAMAI_CONSULTORA=Ana
XNAMAI_PEDIDO_MINIMO=800
# true só em produção (sandbox tem itens < R$ 800)
XNAMAI_PEDIDO_MINIMO_ATIVO=false

# Validação de tabelas no startup (false = só loga erro, não derruba o boot)
VALIDAR_TABELAS_STARTUP=true
